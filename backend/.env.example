# Copy this file to .env and fill in the values.
# .env is git-ignored — never commit real credentials.
#
# Host-run backend defaults:
# - DATABASE_URL=postgresql+psycopg://admin:localpassword@localhost:5432/advisor_db
# - OLLAMA_BASE_URL=http://localhost:11434
# - MINIO_ENDPOINT=http://localhost:9000
#
# Docker-run backend overrides should point to host-published services:
# - DATABASE_URL=postgresql+psycopg://admin:localpassword@host.docker.internal:5432/advisor_db
# - OLLAMA_BASE_URL=http://host.docker.internal:11434
# - MINIO_ENDPOINT=http://host.docker.internal:9000

DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:<port>/<dbname>
LOG_LEVEL=INFO
WHISPER_MODEL=base.en
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-uploads
MINIO_PRESIGN_EXPIRY=300
