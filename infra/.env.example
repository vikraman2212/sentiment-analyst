POSTGRES_USER=admin
POSTGRES_PASSWORD=localpassword
POSTGRES_DB=advisor_db
# Port published to the host. Change if 5432 is already in use locally.
POSTGRES_PORT=5434

# MinIO credentials (must match MINIO_ROOT_USER/PASSWORD in the minio service)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-uploads

# --- Backend service (used when the backend runs inside Compose) ---
# URLs use Docker compose service names so containers can reach each other.
# Ollama is NOT in Compose — it must run on the host. host.docker.internal is
# resolved by the extra_hosts entry in the backend service definition.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EXTRACTION_MODEL=llama3.2
OLLAMA_GENERATION_MODEL=llama3.2
LOG_LEVEL=INFO
WHISPER_MODEL=base.en
SCHEDULER_SECRET=change-me-in-production
# Set OTEL_ENABLED=true to export traces to the Jaeger container (port 4318).
OTEL_ENABLED=true
OTEL_ENDPOINT=http://jaeger:4318

# Redis queue (required when QUEUE_BACKEND=redis — used by the standalone agents profile)
REDIS_URL=redis://localhost:6379
